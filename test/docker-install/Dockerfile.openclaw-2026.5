FROM node:22-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl jq procps python3 && rm -rf /var/lib/apt/lists/*
RUN npm install -g openclaw@2026.5.4 2>&1 | tail -5
COPY blockrun-clawrouter-0.12.186.tgz /tmp/clawrouter.tgz
COPY run-e2e.sh /run-e2e.sh
RUN chmod +x /run-e2e.sh
RUN openclaw --version
CMD ["/run-e2e.sh"]
